{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blocks/testimonial",
	"version": "0.1.0",
	"title": "Testimonial",
	"category": "design",
	"icon": "smiley",
	"description": "Bloque para cargar reseñas google de un negocio.",
	"attributes": {
		"uniqueId": {
			"type": "string",
			"default": ""
		},
		"placeId": {
			"type": "string",
			"default": ""
		},
		"apiKey": {
			"type": "string",
			"default": ""
		},
		"cantidad": {
			"type": "number",
			"default": 4
		}
	},
	"example": {},
	"supports": {
		"html": false
	},
	"textdomain": "testimonial",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./testimonial.css",
	"style": "file:./style-testimonial.css",
	"render": "file:./render.php"
}