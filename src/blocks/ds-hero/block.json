{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mis-bloques/ds-hero",
	"version": "0.1.0",
	"title": "Hero Section",
	"category": "design",
	"icon": "cover-image",
	"description": "Bloque hero personalizable con imagen con mascara",
	"textdomain": "ds-hero",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["wide", "full"]
	},
	"attributes": {
		"uniqueID": {
			"type": "string",
			"default": ""
		},
		"backgroundType": {
			"type": "string",
			"default": "color"
		},
		"backgroundColor": {
			"type": "string",
			"default": "#0d1b3e"
		},
		"backgroundGradient": {
			"type": "string",
			"default": ""
		},
		"backgroundImage": {
			"type": "object",
			"default": {
				"url": "",
				"id": 0,
				"size": "cover",
				"focalPoint": { "x": 0.5, "y": 0.5 }
			}
		},
		"backgroundImagePosition": {
			"type": "string",
			"default": "center center"
		},
		"backgroundImageSize": {
			"type": "string",
			"default": "cover"
		},
		"backgroundImageRepeat": {
			"type": "boolean",
			"default": false
		},
		"backgroundImageAttachment": {
			"type": "string",
			"default": "scroll"
		},
		"overlayColor": {
			"type": "string",
			"default": "#000000"
		},
		"overlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"maskEnabled": {
			"type": "boolean",
			"default": true
		},
		"maskedImageUrl": {
			"type": "string",
			"default": ""
		},
		"maskedImageId": {
			"type": "number",
			"default": 0
		},
		"maskImageUrl": {
			"type": "string",
			"default": ""
		},
		"maskImageId": {
			"type": "number",
			"default": 0
		},
		"maskPositionPreset": {
			"type": "string",
			"default": "bottom right"
		},
		"maskPositionX": {
			"type": "number",
			"default": ""
		},
		"maskPositionY": {
			"type": "number",
			"default": ""
		},
		"maskPositionXUnit": {
			"type": "string",
			"default": "%"
		},
		"maskPositionYUnit": {
			"type": "string",
			"default": "%"
		},
		"maskWidth": {
			"type": "number",
			"default": 480
		},
		"maskHeight": {
			"type": "number",
			"default": 420
		},
		"contentWidth": {
			"type": "string",
			"default": "contained"
		},
		"contentMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"contentPosition": {
			"type": "string",
			"default": "left"
		},
		"verticalAlign": {
			"type": "string",
			"default": "center"
		},
		"paddingDesktop": {
			"type": "array",
			"default": [60, 40, 60, 40]
		},
		"paddingTablet": {
			"type": "array",
			"default": [200, 24, 48, 24]
		},
		"paddingMobile": {
			"type": "array",
			"default": [180, 20, 40, 20]
		},
		"minHeight": {
			"type": "number",
			"default": 480
		},
		"minHeightTablet": {
			"type": "number",
			"default": 520
		},
		"minHeightMobile": {
			"type": "number",
			"default": 400
		},
		"customCSS": {
			"type": "string",
			"default": ""
		}
	},
  "editorScript": "file:../../index.js",
  "editorStyle": "file:../../index.css",
  "style": "file:../../style-index.css"
}
